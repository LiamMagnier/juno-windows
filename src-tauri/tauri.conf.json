{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Juno",
  "version": "0.1.0",
  "identifier": "dev.liams.juno.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Juno",
        "label": "main",
        "width": 1240,
        "height": 800,
        "minWidth": 760,
        "minHeight": 540,
        "center": true,
        "decorations": false,
        "shadow": true,
        "transparent": false,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "font-src": "'self' data:",
        "media-src": "'self' blob: data:",
        "connect-src": "'self' ipc: http://ipc.localhost https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* wss:",
        "frame-src": "'self' blob: data:",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "withGlobalTauri": false
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["juno"]
      }
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/OWNER/juno-windows/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Juno — your personal AI assistant",
    "longDescription": "Juno for Windows is the native desktop client for your Juno account: chat, projects, memory, connectors, scheduled tasks, voice, and a local coding agent.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": false,
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "Juno"
      }
    }
  }
}
