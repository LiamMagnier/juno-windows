{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Baseline capability for the main Juno window. The privileged surface is the explicit juno:* command set plus narrowly-scoped plugin permissions — no fs, shell, or http plugin access from the webview.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "allow-secret-set",
    "allow-secret-get",
    "allow-secret-delete",
    "allow-host-info",
    "allow-set-window-material",
    "allow-auth-configure",
    "allow-auth-exchange",
    "allow-auth-has-session",
    "allow-auth-sign-out",
    "allow-api-request",
    "allow-api-stream",
    "allow-api-stream-cancel",
    "allow-api-upload-path",
    "allow-api-upload-bytes",
    "allow-voice-connect",
    "allow-voice-send-text",
    "allow-voice-send-audio",
    "allow-voice-close",
    "allow-workspace-pick",
    "allow-workspace-list",
    "allow-workspace-set-mode",
    "allow-workspace-revoke",
    "allow-ws-list",
    "allow-ws-read",
    "allow-ws-write",
    "allow-ws-delete-file",
    "allow-ws-search",
    "allow-ws-snapshot",
    "allow-ws-restore-to-before",
    "allow-ws-changed-paths",
    "allow-pty-run",
    "allow-pty-write",
    "allow-pty-kill",
    "allow-pty-kill-session",
    "allow-git-status",
    "allow-git-diff",
    "allow-git-log",
    "allow-git-commit",
    "allow-quick-get-settings",
    "allow-quick-update-settings",
    "allow-quick-open-main",
    "allow-quick-main-startup",
    "allow-quick-quit",
    "deep-link:default",
    "dialog:allow-open",
    "process:allow-restart",
    "updater:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    }
  ]
}
